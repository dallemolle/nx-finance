// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                 @id @default(cuid())
  email              String                 @unique
  password           String
  status_2fa         Boolean                @default(false)
  secret_2fa         String?
  transactions       Transaction[]
  categories         Category[]
  paymentMethods     PaymentMethod[]
  institutions       FinancialInstitution[]
  mappingSuggestions MappingSuggestion[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

enum TransactionStatus {
  PENDENTE
  PAGO
  ATRASADO
}

enum TransactionType {
  ENTRADA
  SAIDA
}

model Transaction {
  id                String            @id @default(cuid())
  descricao         String
  valor             Decimal           @db.Decimal(10, 2)
  data_lancamento   DateTime          @default(now())
  data_vencimento   DateTime
  data_pagamento    DateTime?
  status            TransactionStatus @default(PENDENTE)
  tipo              TransactionType
  is_invoice_header Boolean           @default(false)

  // --- Controle de Provisão e Parcelamento ---
  is_provisioned           Boolean  @default(false)
  is_installment           Boolean  @default(false)
  current_installment      Int?
  total_installments       Int?
  unique_installment_group String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoria_id String
  category     Category @relation(fields: [categoria_id], references: [id])

  tipo_pagamento_id String
  paymentMethod     PaymentMethod @relation(fields: [tipo_pagamento_id], references: [id])

  institution_id String
  institution    FinancialInstitution @relation(fields: [institution_id], references: [id])

  invoiceItems CreditCardInvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditCardInvoiceItem {
  id                       String    @id @default(cuid())
  descricao                String
  valor                    Decimal   @db.Decimal(10, 2)
  data_compra              DateTime
  data_vencimento_original DateTime?

  // --- Controle de Provisão e Parcelamento ---
  is_provisioned           Boolean  @default(false)
  is_installment           Boolean  @default(false)
  current_installment      Int?
  total_installments       Int?
  unique_installment_group String?

  // Vinculação estrita ao cartão/banco emissor (para filtro na conciliação)
  institution_id String?
  institution    FinancialInstitution? @relation(fields: [institution_id], references: [id])

  // transactionId é opcional: itens provisionados existem sem fatura vinculada
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  categoria_id String
  category     Category @relation(fields: [categoria_id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id    String          @id @default(cuid())
  nome  String
  cor   String
  icone String
  tipo  TransactionType

  userId                 String
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions           Transaction[]
  mappingSuggestions     MappingSuggestion[]
  creditCardInvoiceItems CreditCardInvoiceItem[]

  @@unique([nome, userId, tipo])
}

model PaymentMethod {
  id   String @id @default(cuid())
  nome String

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([nome, userId])
}

model MappingSuggestion {
  id          String @id @default(cuid())
  search_term String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoria_id String
  category     Category @relation(fields: [categoria_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([search_term, userId])
}

model FinancialInstitution {
  id       String  @id @default(cuid())
  nome     String
  cor      String?
  metadata Json?   @default("{}")

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  creditCardInvoiceItems CreditCardInvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nome, userId])
}
